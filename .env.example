# OpenMythos 連携 — 環境変数サンプル
#
# ローカル: このファイルを .env.local にコピーして値を設定し、`vercel dev` で起動。
#           cp .env.example .env.local
# 本番:     Vercel Project Settings → Environment Variables、または下記 CLI で登録。
#
#   vercel env add OPENMYTHOS_BASE_URL production
#   vercel env add OPENMYTHOS_API_KEY  production
#   (Preview / Development も必要なら同様に追加)

# OpenMythos サーバーの URL(末尾スラッシュ不要)
OPENMYTHOS_BASE_URL=https://openmythos.example.com

# OpenMythos 側 `API_KEY` と一致させる Bearer トークン
OPENMYTHOS_API_KEY=replace-with-real-token
